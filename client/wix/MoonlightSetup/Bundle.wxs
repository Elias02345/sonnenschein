<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal" xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="Sonnenschein Client"
          Version="!(bind.PackageVersion.Moonlight_x64)"
          Manufacturer="Sonnenschein Project"
          UpgradeCode="867775ba-defc-4799-9b38-b751805595e1"
          HelpUrl="https://github.com/Elias02345/sonnenschein"
          UpdateUrl="https://github.com/Elias02345/sonnenschein/releases"
          DisableModify="yes"
          IconSourceFile="..\..\app\moonlight.ico">

    <bal:Condition Message="Sonnenschein Client requires Windows 10 or later." Condition="VersionNT &gt;= v10.0" />
    <bal:Condition Message="Sonnenschein Client requires an x64 version of Windows." Condition="(VersionNT64 AND NOT NativeMachine) OR (NativeMachine = 34404)" />

    <Variable Name="InstallFolder" Type="formatted" Value="[ProgramFiles6432Folder]Sonnenschein Client" />

    <!-- Define "Add desktop shortcut" -checkbox's state by defining a variable
         which has same name as the checkbox has. Value 1 means that checkbox
         is checked, 0 means that is unchecked-->
    <!-- Set checkbox's state as checked by default -->
    <Variable Name="AddDesktopShortcutCheckbox" Type="numeric" Value="1" />
    <!-- Get checkbox's state from registry if present. The registry value
         "DesktopShortcutInstallState" is set in Product.wxs. -->
    <util:RegistrySearch Variable="HasDesktopShortcutInstallStateRegKey" Root="HKCU" Key="Software\Sonnenschein" Value="DesktopShortcutInstallState" Result="exists" />
    <util:RegistrySearch Variable="AddDesktopShortcutCheckbox" Root="HKCU" Key="Software\Sonnenschein" Value="DesktopShortcutInstallState" Condition="HasDesktopShortcutInstallStateRegKey" />

    <util:ProductSearch Id="VCREDIST_14_x64"
                        UpgradeCode="$(var.VCREDIST_X64_UPGRADE_CODE)"
